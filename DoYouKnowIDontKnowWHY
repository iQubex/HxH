local function updateThirdPerson()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if not originalCameraZoomLimits then
        originalCameraZoomLimits = {
            Min = LocalPlayer.CameraMinZoomDistance,
            Max = LocalPlayer.CameraMaxZoomDistance
        }
    end

    if Settings.ThirdPersonEnabled then
        if LocalPlayer.CameraMinZoomDistance ~= Settings.CameraDistance then
            LocalPlayer.CameraMinZoomDistance = Settings.CameraDistance
        end
        if LocalPlayer.CameraMaxZoomDistance ~= Settings.CameraDistance then
            LocalPlayer.CameraMaxZoomDistance = Settings.CameraDistance
        end
        if humanoid then
            local targetOffset = Vector3.new(Settings.CameraOffsetX, Settings.CameraOffsetY, Settings.CameraOffsetZ)
            if humanoid.CameraOffset ~= targetOffset then
                humanoid.CameraOffset = targetOffset
            end
        end
    else
        if originalCameraZoomLimits then
            if LocalPlayer.CameraMinZoomDistance ~= originalCameraZoomLimits.Min then
                LocalPlayer.CameraMinZoomDistance = originalCameraZoomLimits.Min
            end
            if LocalPlayer.CameraMaxZoomDistance ~= originalCameraZoomLimits.Max then
                LocalPlayer.CameraMaxZoomDistance = originalCameraZoomLimits.Max
            end
        end
        if humanoid then
            if humanoid.CameraOffset ~= Vector3.new(0, 0, 0) then
                humanoid.CameraOffset = Vector3.new(0, 0, 0)
            end
        end
    end
end

local function applyLightingSettings()
    if not originalLightingSettings then
        originalLightingSettings = {
            Ambient = game.Lighting.Ambient,
            OutdoorAmbient = game.Lighting.OutdoorAmbient,
            TimeOfDay = game.Lighting.TimeOfDay
        }
        for _, child in ipairs(game.Lighting:GetChildren()) do
            if child:IsA("Sky") then
                table.insert(originalSkies, {parent = child.Parent, instance = child})
            end
        end
    end

    if Settings.WorldLightingEnabled then
        if game.Lighting.Ambient ~= Settings.WorldAmbient then
            game.Lighting.Ambient = Settings.WorldAmbient
        end
        if game.Lighting.OutdoorAmbient ~= Settings.WorldOutdoorAmbient then
            game.Lighting.OutdoorAmbient = Settings.WorldOutdoorAmbient
        end
        local timeStr = string.format("%.2f", Settings.WorldTimeOfDay)
        if game.Lighting.TimeOfDay ~= timeStr then
            game.Lighting.TimeOfDay = timeStr
        end
    else
        if game.Lighting.Ambient ~= originalLightingSettings.Ambient then
            game.Lighting.Ambient = originalLightingSettings.Ambient
        end
        if game.Lighting.OutdoorAmbient ~= originalLightingSettings.OutdoorAmbient then
            game.Lighting.OutdoorAmbient = originalLightingSettings.OutdoorAmbient
        end
        if game.Lighting.TimeOfDay ~= originalLightingSettings.TimeOfDay then
            game.Lighting.TimeOfDay = originalLightingSettings.TimeOfDay
        end
    end

    if Settings.WorldColorCorrection then
        if not colorCorrectionInstance or colorCorrectionInstance.Parent ~= game.Lighting then
            if colorCorrectionInstance then colorCorrectionInstance:Destroy() end
            colorCorrectionInstance = Instance.new("ColorCorrectionEffect")
            colorCorrectionInstance.Parent = game.Lighting
        end
        if colorCorrectionInstance.Saturation ~= Settings.WorldSaturation then
            colorCorrectionInstance.Saturation = Settings.WorldSaturation
        end
        if colorCorrectionInstance.Contrast ~= Settings.WorldContrast then
            colorCorrectionInstance.Contrast = Settings.WorldContrast
        end
        if not colorCorrectionInstance.Enabled then
            colorCorrectionInstance.Enabled = true
        end
    else
        if colorCorrectionInstance and colorCorrectionInstance.Enabled then
            colorCorrectionInstance.Enabled = false
        end
    end

    if Settings.WorldSkybox then
        for _, skyData in ipairs(originalSkies) do
            if skyData.instance and skyData.instance.Parent then
                skyData.instance.Parent = nil
            end
        end
        if not customSkyboxInstance or customSkyboxInstance.Parent ~= game.Lighting then
            if customSkyboxInstance then customSkyboxInstance:Destroy() end
            customSkyboxInstance = Instance.new("Sky")
            customSkyboxInstance.Name = "CustomSkybox"
            customSkyboxInstance.SkyboxBk = "rbxassetid://600830446"
            customSkyboxInstance.SkyboxDn = "rbxassetid://600830721"
            customSkyboxInstance.SkyboxFt = "rbxassetid://600830446"
            customSkyboxInstance.SkyboxLf = "rbxassetid://600830446"
            customSkyboxInstance.SkyboxRt = "rbxassetid://600830446"
            customSkyboxInstance.SkyboxUp = "rbxassetid://600830721"
            customSkyboxInstance.SunTextureId = ""
            customSkyboxInstance.MoonTextureId = ""
            customSkyboxInstance.Parent = game.Lighting
        end
    else
        if customSkyboxInstance then
            customSkyboxInstance:Destroy()
            customSkyboxInstance = nil
        end
        for _, skyData in ipairs(originalSkies) do
            if skyData.instance and skyData.instance.Parent ~= skyData.parent then
                skyData.instance.Parent = skyData.parent
            end
        end
    end
end

local function cleanupLighting()
    if originalLightingSettings then
        game.Lighting.Ambient = originalLightingSettings.Ambient
        game.Lighting.OutdoorAmbient = originalLightingSettings.OutdoorAmbient
        game.Lighting.TimeOfDay = originalLightingSettings.TimeOfDay
    end
    if colorCorrectionInstance then
        colorCorrectionInstance:Destroy()
        colorCorrectionInstance = nil
    end
    if customSkyboxInstance then
        customSkyboxInstance:Destroy()
        customSkyboxInstance = nil
    end
    for _, skyData in ipairs(originalSkies) do
        if skyData.instance then
            skyData.instance.Parent = skyData.parent
        end
    end
    table.clear(originalSkies)
    originalLightingSettings = nil
end

