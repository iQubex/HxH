-- NEW: Helper to locate waist connection joints dynamically
local function getWaistJoint(character)
    if not character then return nil end
    if character:FindFirstChild("Torso") then
        -- R6 Rig structure
        local hrp = character:FindFirstChild("HumanoidRootPart")
        return hrp and hrp:FindFirstChild("RootJoint")
    elseif character:FindFirstChild("UpperTorso") then
        -- R15 Rig structure
        local upperTorso = character.UpperTorso
        local waist = upperTorso:FindFirstChild("Waist")
        if waist then
            return waist
        end
        local lowerTorso = character:FindFirstChild("LowerTorso")
        return lowerTorso and (lowerTorso:FindFirstChild("RootJoint") or lowerTorso:FindFirstChild("Root"))
    end
    return nil
end

