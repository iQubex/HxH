    -- Update Crosshair
    local crosshairEnabled = Settings.CrosshairEnabled
    local viewportSize = Camera.ViewportSize
    local cx, cy = viewportSize.X / 2, viewportSize.Y / 2
    
    local size = Settings.CrosshairSize
    local thickness = Settings.CrosshairThickness
    local gap = Settings.CrosshairGap
    local color = Settings.CrosshairRainbow and Color3.fromHSV((tick() % 5) / 5, 1, 1) or Settings.CrosshairColor
    
    for i = 1, 4 do
        crosshairLines[i].Visible = crosshairEnabled
        if crosshairEnabled then
            crosshairLines[i].Thickness = thickness
            crosshairLines[i].Color = color
            crosshairLines[i].Transparency = 1
        end
    end
    
    if crosshairEnabled then
        -- Left
        crosshairLines[1].From = Vector2.new(cx - gap - size, cy)
        crosshairLines[1].To = Vector2.new(cx - gap, cy)
        -- Right
        crosshairLines[2].From = Vector2.new(cx + gap, cy)
        crosshairLines[2].To = Vector2.new(cx + gap + size, cy)
        -- Up
        crosshairLines[3].From = Vector2.new(cx, cy - gap - size)
        crosshairLines[3].To = Vector2.new(cx, cy - gap)
        -- Down
        crosshairLines[4].From = Vector2.new(cx, cy + gap)
        crosshairLines[4].To = Vector2.new(cx, cy + gap + size)
    end

    -- Update Hitmarker
    local hitmarkerDuration = 0.25
    local elapsedHit = tick() - lastHitTime
    if Settings.HitmarkerEnabled and elapsedHit < hitmarkerDuration then
        local intensity = 1 - (elapsedHit / hitmarkerDuration)
        local hSize = 6
        
        hitmarkerLines[1].From = Vector2.new(cx - hSize, cy - hSize)
        hitmarkerLines[1].To = Vector2.new(cx + hSize, cy + hSize)
        hitmarkerLines[1].Transparency = intensity
        hitmarkerLines[1].Visible = true
        
        hitmarkerLines[2].From = Vector2.new(cx + hSize, cy - hSize)
        hitmarkerLines[2].To = Vector2.new(cx - hSize, cy + hSize)
        hitmarkerLines[2].Transparency = intensity
        hitmarkerLines[2].Visible = true
    else
        hitmarkerLines[1].Visible = false
        hitmarkerLines[2].Visible = false
    end

    -- Update 2D Box ESP, Health, Names, Skeleton, and Snaplines
    local localPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Camera.CFrame.Position
    for player, data in pairs(State.EspBoxes) do
        local character = player.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        local head = character and character:FindFirstChild("Head")
        local isEnemy = not Settings.TeamCheck or player.Team ~= LocalPlayer.Team
        
        local distance = hrp and math.floor((hrp.Position - localPos).Magnitude) or 99999
        
        if isEnemy and character and humanoid and humanoid.Health > 0 and hrp and head and distance <= Settings.EspMaxDistance then
            local hrpPos, hrpOnScreen = Camera:WorldToViewportPoint(hrp.Position)
            if hrpOnScreen then
                local x, y, width, height = getBoundingBox2D(character)
                
                -- 1. Main Box / Corner Lines
                if Settings.BoxEnabled then
                    if Settings.BoxType == "Full" then
                        -- Hide corner lines
                        for _, line in ipairs(data.CornerLines) do line.Visible = false end
                        for _, line in ipairs(data.CornerOutlines) do line.Visible = false end
                        
                        -- Show Full Box Outline
                        if Settings.BoxOutline then
                            data.BoxOutline.Size = Vector2.new(width + 2, height + 2)
                            data.BoxOutline.Position = Vector2.new(x - 1, y - 1)
                            data.BoxOutline.Thickness = boxThicknessValue + 2
                            data.BoxOutline.Transparency = boxTransparencyValue
                            data.BoxOutline.Visible = true
                        else
                            data.BoxOutline.Visible = false
                        end
                        
                        -- Show Full Box
                        data.Box.Size = Vector2.new(width, height)
                        data.Box.Position = Vector2.new(x, y)
                        data.Box.Thickness = boxThicknessValue
                        data.Box.Color = boxColorValue
                        data.Box.Transparency = boxTransparencyValue
                        data.Box.Visible = true
                    elseif Settings.BoxType == "Corner" then
                        -- Hide Full Box and Outline
                        data.Box.Visible = false
                        data.BoxOutline.Visible = false
                        
                        -- Calculate Corner Line positions
                        local len = math.clamp(width * 0.2, 5, 15)
                        local corners = {
                            -- Top-Left
                            {From = Vector2.new(x, y), To = Vector2.new(x + len, y)},
                            {From = Vector2.new(x, y), To = Vector2.new(x, y + len)},
                            -- Top-Right
                            {From = Vector2.new(x + width, y), To = Vector2.new(x + width - len, y)},
                            {From = Vector2.new(x + width, y), To = Vector2.new(x + width, y + len)},
                            -- Bottom-Left
                            {From = Vector2.new(x, y + height), To = Vector2.new(x + len, y + height)},
                            {From = Vector2.new(x, y + height), To = Vector2.new(x, y + height - len)},
                            -- Bottom-Right
                            {From = Vector2.new(x + width, y + height), To = Vector2.new(x + width - len, y + height)},
                            {From = Vector2.new(x + width, y + height), To = Vector2.new(x + width, y + height - len)}
                        }
                        
                        for i, coords in ipairs(corners) do
                            local line = data.CornerLines[i]
                            local outline = data.CornerOutlines[i]
                            
                            if Settings.BoxOutline then
                                outline.From = coords.From
                                outline.To = coords.To
                                outline.Thickness = boxThicknessValue + 2
                                outline.Transparency = boxTransparencyValue
                                outline.Visible = true
                            else
                                outline.Visible = false
                            end
                            
                            line.From = coords.From
                            line.To = coords.To
                            line.Thickness = boxThicknessValue
                            line.Color = boxColorValue
                            line.Transparency = boxTransparencyValue
                            line.Visible = true
                        end
                    end
                else
                    data.Box.Visible = false
                    data.BoxOutline.Visible = false
                    for _, line in ipairs(data.CornerLines) do line.Visible = false end
                    for _, line in ipairs(data.CornerOutlines) do line.Visible = false end
                end
                
                -- 2. Player Name Label & Distance Text
                local currentFont = fontMapping[Settings.TextFont] or 0
                local currentSize = Settings.TextSize or 14
                
                if espNamesEnabled then
                    data.Name.Text = player.Name
                    data.Name.Position = Vector2.new(hrpPos.X, y - currentSize - 2)
                    data.Name.Font = currentFont
                    data.Name.Size = currentSize
                    data.Name.Color = Color3.fromRGB(255, 255, 255)
                    data.Name.Visible = true
                else
                    data.Name.Visible = false
                end
                
                local localPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Camera.CFrame.Position
                local distance = math.floor((hrp.Position - localPos).Magnitude)
                if espNamesEnabled then
                    data.DistanceText.Text = tostring(distance) .. "m"
                    data.DistanceText.Position = Vector2.new(hrpPos.X, y + height + 2)
                    data.DistanceText.Font = currentFont
                    data.DistanceText.Size = currentSize - 2
                    data.DistanceText.Color = Color3.fromRGB(200, 200, 200)
                    data.DistanceText.Visible = true
                else
                    data.DistanceText.Visible = false
                end
                
                -- 3. Vertical Health Bar
                if espHealthEnabled then
                    local healthRatio = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
                    local barX = x - 6
                    local barYStart = y + height
                    local barYEnd = y
                    
                    data.HealthBarBack.From = Vector2.new(barX, barYStart)
                    data.HealthBarBack.To = Vector2.new(barX, barYEnd)
                    data.HealthBarBack.Visible = true
                    
                    local healthHeight = height * healthRatio
                    data.HealthBar.From = Vector2.new(barX, barYStart)
                    data.HealthBar.To = Vector2.new(barX, barYStart - healthHeight)
                    
                    local barColor
                    if Settings.HealthBarStyle == "Solid" then
                        barColor = Color3.fromRGB(0, 255, 0)
                    else
                        -- Gradient or Segmented styles use dynamic RGB interpolation from green to yellow to red
                        if healthRatio >= 0.5 then
                            local t = (healthRatio - 0.5) / 0.5
                            barColor = Color3.fromRGB(math.floor(255 * (1 - t)), 255, 0)
                        elseif healthRatio >= 0.25 then
                            local t = (healthRatio - 0.25) / 0.25
                            barColor = Color3.fromRGB(255, math.floor(255 * t), 0)
                        else
                            barColor = Color3.fromRGB(255, 0, 0)
                        end
                    end
                    data.HealthBar.Color = barColor
                    data.HealthBar.Visible = true
                    
                    -- Dividers for Segmented style
                    for _, div in ipairs(data.HealthDividers) do div.Visible = false end
                    if Settings.HealthBarStyle == "Segmented" and healthHeight > 0 then
                        local segmentCount = 10
                        for i = 1, segmentCount - 1 do
                            local div = data.HealthDividers[i]
                            local divY = barYStart - (height * (i / segmentCount))
                            if divY > (barYStart - healthHeight) then
                                div.From = Vector2.new(barX - 1.5, divY)
                                div.To = Vector2.new(barX + 1.5, divY)
                                div.Visible = true
                            end
                        end
                    end
                else
                    data.HealthBarBack.Visible = false
                    data.HealthBar.Visible = false
                    for _, div in ipairs(data.HealthDividers) do div.Visible = false end
                end

                -- 4. Skeleton ESP Connection Lines
                if skeletonEnabled then
                    local skel = getSkeletonParts(character)
                    if skel then
                        local mid = skel.SpineMid or skel.SpineBase
                        drawLine(data.Skeleton[1], skel.Head, mid)
                        drawLine(data.Skeleton[2], mid, skel.LeftHand)
                        drawLine(data.Skeleton[3], mid, skel.RightHand)
                        drawLine(data.Skeleton[4], skel.SpineBase, skel.LeftFoot)
                        drawLine(data.Skeleton[5], skel.SpineBase, skel.RightFoot)
                    else
                        for _, line in ipairs(data.Skeleton) do line.Visible = false end
                    end
                else
                    for _, line in ipairs(data.Skeleton) do line.Visible = false end
                end

                -- 5. Screen Snaplines
                if snaplinesEnabled then
                    local viewportSizeVal = Camera.ViewportSize
                    local fromPoint = Vector2.new(viewportSizeVal.X / 2, viewportSizeVal.Y)
                    if Settings.SnaplineOrigin == "Top" then
                        fromPoint = Vector2.new(viewportSizeVal.X / 2, 0)
                    elseif Settings.SnaplineOrigin == "Center" then
                        fromPoint = Vector2.new(viewportSizeVal.X / 2, viewportSizeVal.Y / 2)
                    end
                    
                    if Settings.SnaplineStyle == "Solid" then
                        for _, dash in ipairs(data.SnaplineDashes) do dash.Visible = false end
                        
                        data.Snapline.From = fromPoint
                        data.Snapline.To = Vector2.new(hrpPos.X, hrpPos.Y)
                        data.Snapline.Color = boxColorValue
                        data.Snapline.Thickness = Settings.SnaplineThickness or 1.0
                        data.Snapline.Transparency = Settings.SnaplineTransparency or 1.0
                        data.Snapline.Visible = true
                    elseif Settings.SnaplineStyle == "Dotted" then
                        data.Snapline.Visible = false
                        
                        local toPoint = Vector2.new(hrpPos.X, hrpPos.Y)
                        local dir = toPoint - fromPoint
                        local dashCount = 15
                        
                        for i = 1, dashCount do
                            local dash = data.SnaplineDashes[i]
                            local tStart = (i - 1) / dashCount
                            local tEnd = (i - 0.5) / dashCount
                            
                            dash.From = fromPoint + dir * tStart
                            dash.To = fromPoint + dir * tEnd
                            dash.Color = boxColorValue
                            dash.Thickness = Settings.SnaplineThickness or 1.0
                            dash.Transparency = Settings.SnaplineTransparency or 1.0
                            dash.Visible = true
                        end
                    end
                else
                    data.Snapline.Visible = false
                    for _, dash in ipairs(data.SnaplineDashes) do dash.Visible = false end
                end
            else
                data.Box.Visible = false
                data.BoxOutline.Visible = false
                data.Name.Visible = false
                data.DistanceText.Visible = false
                data.HealthBarBack.Visible = false
                data.HealthBar.Visible = false
                data.Snapline.Visible = false
                for _, line in ipairs(data.CornerLines) do line.Visible = false end
                for _, line in ipairs(data.CornerOutlines) do line.Visible = false end
                for _, div in ipairs(data.HealthDividers) do div.Visible = false end
                for _, line in ipairs(data.Skeleton) do line.Visible = false end
                for _, dash in ipairs(data.SnaplineDashes) do dash.Visible = false end
            end
        else
            data.Box.Visible = false
            data.BoxOutline.Visible = false
            data.Name.Visible = false
            data.DistanceText.Visible = false
            data.HealthBarBack.Visible = false
            data.HealthBar.Visible = false
            data.Snapline.Visible = false
            for _, line in ipairs(data.CornerLines) do line.Visible = false end
            for _, line in ipairs(data.CornerOutlines) do line.Visible = false end
            for _, div in ipairs(data.HealthDividers) do div.Visible = false end
            for _, line in ipairs(data.Skeleton) do line.Visible = false end
            for _, dash in ipairs(data.SnaplineDashes) do dash.Visible = false end
        end
    end
end)

-- UserInputService keyboard/mouse events for Lock Bind, UI Hide, and Tracer trigger
addConnection(UserInputService.InputBegan, function(input, processed)
    if processed then return end
    local keyName = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode.Name or input.UserInputType.Name
    
    -- UI toggle button
    if keyName == Settings.ToggleUIKey then
        Library:Toggle()
    end
    
    -- Lock target button
    if keyName == Settings.LockKey then
        State.LockPressed = true
        if Settings.LockMode == "Toggle" then
            State.LockToggled = not State.LockToggled
        end
    end

    -- NEW: Bullet tracer trigger on local mouse click
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local character = LocalPlayer.Character
        if character and character:FindFirstChildOfClass("Tool") then
            local mouse = LocalPlayer:GetMouse()
            local targetPoint = mouse.Hit.Position
            if Settings.BulletTracersEnabled then
                createBulletTracer(Camera.CFrame.Position, targetPoint)
            end
            if isLockActive() then
                local bestTarget = getBestTarget()
                if bestTarget then
                    local distToTarget = (mouse.Hit.Position - bestTarget.Position).Magnitude
                    if distToTarget < 10 then
                        triggerHitmarker()
                    end
                end
            end
        end
    end
end)

addConnection(UserInputService.InputEnded, function(input)
    local keyName = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode.Name or input.UserInputType.Name
    if keyName == Settings.LockKey then
        State.LockPressed = false
    end
end)

-- NEW: Decoupled Jitter thread running independently of frame rates
local currentJitterYaw = 0
task.spawn(function()
    while true do
        -- Jitter loop wait time regulated by Settings.RotationSpeed
        local waitTime = 1 / math.max(rotationSpeedValue, 1)
        task.wait(waitTime)
        
        if Settings.AntiAimEnabled and Settings.YawMode == "Jitter" then
            local minVal = tonumber(Settings.JitterMinAngle) or -45
            local maxVal = tonumber(Settings.JitterMaxAngle) or 45
            if minVal > maxVal then
                minVal, maxVal = maxVal, minVal
            end
            -- Safe random calculation supporting float ranges and preventing crash when equal or swapped
            local randomDegree = minVal == maxVal and minVal or (minVal + math.random() * (maxVal - minVal))
            currentJitterYaw = math.rad(randomDegree)
        end
    end
end)

-- NEW: Anti-Aim System execution connected to Heartbeat (Waist Down-Pitch with Procedural Angle Slider)
addConnection(RunService.Heartbeat, function()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    
    if hrp and humanoid and humanoid.Health > 0 then
        -- Find waist joint dynamically using rig format scanner (R6/R15 compatible)
        local joint = getWaistJoint(character)
        if joint and joint:IsA("Motor6D") then
            if joint ~= lastRootJoint then
                lastRootJoint = joint
                originalC0 = joint.C0
            end
        end

        if antiAimEnabled then
            if humanoid.Sit then return end
            
            local currentCF = hrp.CFrame
            local speedMultiplier = rotationSpeedValue * 5
            
            -- 1. Yaw angle offset calculation
            local yaw = 0
            if Settings.YawMode == "Spin" then
                yaw = (tick() * speedMultiplier) % (math.pi * 2)
            elseif Settings.YawMode == "Jitter" then
                yaw = currentJitterYaw
            elseif Settings.YawMode == "Static" then
                yaw = math.rad(180) -- Face backwards
            end
            
            -- 2. Pitch angle offset calculation (Down mode handled procedurally via C0 to keep feet flat)
            local pitch = 0
            if Settings.PitchMode == "Up" then
                pitch = math.rad(-85)
            elseif Settings.PitchMode == "Down" then
                pitch = 0
            elseif Settings.PitchMode == "Zero" then
                pitch = 0
            end
            
            -- Apply orientation to HRP (Yaw & Up Pitch)
            hrp.CFrame = CFrame.new(currentCF.Position) * CFrame.Angles(pitch, yaw, 0)
            
            -- 3. Procedural waist bending execution
            if joint and originalC0 then
                if Settings.PitchMode == "Down" then
                    -- Bends upper body forwards and downwards by configured PitchAngle degrees, keeping feet flat
                    joint.C0 = originalC0 * CFrame.Angles(math.rad(-Settings.PitchAngle), 0, 0)
                else
                    joint.C0 = originalC0
                end
            end
        else
            -- Reset joint when Anti-Aim is disabled
            if joint and originalC0 then
                joint.C0 = originalC0
            end
        end
    else
        -- Clear local joint cache on character death
        lastRootJoint = nil
        originalC0 = nil
    end
end)

-- Advanced Visual Modifiers (Clone Chams, Third Person & Lighting updates)
local chamsFolder = workspace.CurrentCamera:FindFirstChild("ChamsFolder")
if not chamsFolder then
    chamsFolder = Instance.new("Folder")
    chamsFolder.Name = "ChamsFolder"
    chamsFolder.Parent = workspace.CurrentCamera
end

local function clearPlayerClone(player)
    local cloneModel = playerClones[player]
    if cloneModel then
        cloneModel:Destroy()
        playerClones[player] = nil
    end
end

local materialMapping = {
    ["Neon"] = Enum.Material.Neon,
    ["ForceField"] = Enum.Material.ForceField,
    ["Glass"] = Enum.Material.Glass,
    ["SmoothPlastic"] = Enum.Material.SmoothPlastic
}

local function syncCharacterChams(player, character)
    if not character then return end
    local cloneModel = playerClones[player]
    if not cloneModel or cloneModel.Parent ~= chamsFolder then
        clearPlayerClone(player)
        
        cloneModel = Instance.new("Model")
        cloneModel.Name = player.Name .. "_Chams"
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "ChamsHighlight"
        highlight.Parent = cloneModel
        
        playerClones[player] = cloneModel
        cloneModel.Parent = chamsFolder
    end
    
    -- Dynamically calculate target color and transparency with pulse animation
    local targetColor = Settings.ChamsColor
    local targetTransparency = Settings.FillTransparency
    
    if Settings.ChamsPulseSpeed > 0 then
        local pulse = math.sin(tick() * Settings.ChamsPulseSpeed)
        
        -- Modulate transparency
        targetTransparency = Settings.FillTransparency + pulse * 0.25
        targetTransparency = math.clamp(targetTransparency, 0.05, 0.95)
        
        -- Modulate brightness for Neon to make it pulse in brightness
        if Settings.ChamsMaterial == "Neon" then
            local brightness = 1.0 + pulse * 0.5
            targetColor = Color3.new(
                math.clamp(Settings.ChamsColor.R * brightness, 0, 1),
                math.clamp(Settings.ChamsColor.G * brightness, 0, 1),
                math.clamp(Settings.ChamsColor.B * brightness, 0, 1)
            )
        end
    end
    
    local highlight = cloneModel:FindFirstChild("ChamsHighlight")
    if highlight then
        highlight.FillColor = targetColor
        highlight.OutlineColor = Settings.OutlineColor
        -- If VisibleOnly is enabled, keep Highlight fill fully transparent (1.0) so only Roblox's native materials are visible.
        highlight.FillTransparency = Settings.ChamsVisibleOnly and 1.0 or targetTransparency
        highlight.OutlineTransparency = Settings.ChamsOutlineTransparency
        highlight.DepthMode = Settings.ChamsVisibleOnly and Enum.HighlightDepthMode.Occluded or Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Enabled = true
    end

    -- Synchronize parts
    for _, part in ipairs(character:GetChildren()) do
        -- Exclude HumanoidRootPart to prevent rendering an ugly block in the center of the chams
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local clonedPart = cloneModel:FindFirstChild(part.Name)
            if not clonedPart then
                clonedPart = part:Clone()
                clonedPart:ClearAllChildren()
                clonedPart.Parent = cloneModel
                
                local sBox = Instance.new("SelectionBox")
                sBox.Name = "ChamsOutline"
                sBox.Adornee = clonedPart
                sBox.Parent = clonedPart
            end
            clonedPart.CFrame = part.CFrame
            -- Slightly increase size to prevent Z-fighting and render a beautiful material outline shell
            clonedPart.Size = part.Size + Vector3.new(0.02, 0.02, 0.02)
            clonedPart.CanCollide = false
            clonedPart.Anchored = true
            clonedPart.CastShadow = false
            clonedPart.Material = materialMapping[Settings.ChamsMaterial] or Enum.Material.ForceField
            clonedPart.Color = targetColor
            clonedPart.Transparency = targetTransparency
            
            local sBox = clonedPart:FindFirstChild("ChamsOutline")
            if sBox then
                sBox.Color3 = Settings.OutlineColor
                sBox.Transparency = Settings.ChamsOutlineTransparency
            end
        end
    end
    
    -- Remove extra parts
    for _, clonedPart in ipairs(cloneModel:GetChildren()) do
        if clonedPart:IsA("BasePart") and not character:FindFirstChild(clonedPart.Name) then
            clonedPart:Destroy()
        end
    end
end

local function updateChams()
    if not Settings.ChamsEnabled and not Settings.SelfChamsEnabled then
        for p, _ in pairs(playerClones) do
            clearPlayerClone(p)
        end
        return
    end

    -- Other players chams
    if Settings.ChamsEnabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local character = player.Character
                local isEnemy = not Settings.TeamCheck or player.Team ~= LocalPlayer.Team
                local humanoid = character and character:FindFirstChildOfClass("Humanoid")

                if isEnemy and character and humanoid and humanoid.Health > 0 then
                    syncCharacterChams(player, character)
                else
                    clearPlayerClone(player)
                end
            end
        end
    else
        for player, _ in pairs(playerClones) do
            if player ~= LocalPlayer then
                clearPlayerClone(player)
            end
        end
    end
    
    -- Self chams
    if Settings.SelfChamsEnabled then
        local character = LocalPlayer.Character
        local humanoid = character and character:FindFirstChildOfClass("Humanoid")
        if character and humanoid and humanoid.Health > 0 then
            syncCharacterChams(LocalPlayer, character)
        else
            clearPlayerClone(LocalPlayer)
        end
    else
        clearPlayerClone(LocalPlayer)
    end
    
    -- Cleanup players who left
    for p, _ in pairs(playerClones) do
        if p ~= LocalPlayer and not Players:FindFirstChild(p.Name) then
            clearPlayerClone(p)
        end
    end
end

