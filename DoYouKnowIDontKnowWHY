-- NEW: Trigger Bot checking loop connected to Heartbeat
local lastTriggerTime = 0
addConnection(RunService.Heartbeat, function()
    if not Settings.TriggerBotEnabled then return end
    
    local mouseTarget = LocalPlayer:GetMouse().Target
    if mouseTarget and mouseTarget.Parent then
        local char = mouseTarget.Parent
        if not char:FindFirstChildOfClass("Humanoid") and char.Parent then
            char = char.Parent
        end
        
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local player = Players:GetPlayerFromCharacter(char)
        
        if humanoid and humanoid.Health > 0 and char ~= LocalPlayer.Character then
            local isEnemy = not Settings.TeamCheck or (player and player.Team ~= LocalPlayer.Team)
            if isEnemy then
                local screenPos, onScreen = Camera:WorldToViewportPoint(mouseTarget.Position)
                if onScreen then
                    local mouseLoc = UserInputService:GetMouseLocation()
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mouseLoc).Magnitude
                    
                    if dist <= fovRadiusValue then
                        local now = tick()
                        if now - lastTriggerTime >= (clickDelayValue / 1000) then
                            lastTriggerTime = now
                            triggerHitmarker()
                            
                            task.spawn(function()
                                VirtualInputManager:SendMouseButtonEvent(mouseLoc.X, mouseLoc.Y, 0, true, game, 1)
                                task.wait(0.01)
                                VirtualInputManager:SendMouseButtonEvent(mouseLoc.X, mouseLoc.Y, 0, false, game, 1)
                            end)
                            
                            if Settings.BulletTracersEnabled then
                                createBulletTracer(Camera.CFrame.Position, mouseTarget.Position)
                            end
                        end
                    end
                end
            end
        end
    end
end)

