-- NEW: Bullet Tracer rendering utility
local function createBulletTracer(fromPos, toPos)
    if not Settings.BulletTracersEnabled then return end
    
    local line = Drawing.new("Line")
    line.Thickness = 1.8
    line.Transparency = 1
    line.Visible = true
    
    local color = Settings.BulletTracerRainbow and Color3.fromHSV((tick() % 5) / 5, 1, 1) or Settings.TracerColor
    line.Color = color
    
    local tracerInfo = {
        Line = line,
        Connection = nil
    }
    table.insert(activeBulletTracers, tracerInfo)
    
    local duration = Settings.BulletTracerFadeTime or 1.0
    local startTime = tick()
    
    local connection
    connection = RunService.RenderStepped:Connect(function()
        local elapsed = tick() - startTime
        if elapsed >= duration or not tracerInfo.Line then
            if tracerInfo.Line then
                tracerInfo.Line:Remove()
                tracerInfo.Line = nil
            end
            if connection then
                connection:Disconnect()
                tracerInfo.Connection = nil
            end
            local idx = table.find(activeBulletTracers, tracerInfo)
            if idx then
                table.remove(activeBulletTracers, idx)
            end
            return
        end
        
        local screenFrom, onScreenFrom = Camera:WorldToViewportPoint(fromPos)
        local screenTo, onScreenTo = Camera:WorldToViewportPoint(toPos)
        
        if onScreenFrom and onScreenTo then
            tracerInfo.Line.From = Vector2.new(screenFrom.X, screenFrom.Y)
            tracerInfo.Line.To = Vector2.new(screenTo.X, screenTo.Y)
            tracerInfo.Line.Transparency = 1 - (elapsed / duration)
            if Settings.BulletTracerRainbow then
                tracerInfo.Line.Color = Color3.fromHSV((tick() % 5) / 5, 1, 1)
            else
                tracerInfo.Line.Color = Settings.TracerColor
            end
            tracerInfo.Line.Visible = true
        else
            tracerInfo.Line.Visible = false
        end
    end)
    tracerInfo.Connection = connection
end

-- Helper function to calculate a stable 2D screen bounding box for a character (prevents box tilting/yamulma)
local function getBoundingBox2D(character)
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0, 0, 0, 0 end
    
    local size = Vector3.new(4, 6, 4)
    local halfSize = size / 2
    
    -- Create a CFrame centered at the HumanoidRootPart but aligned to the camera rotation to keep the projected 2D box upright and stable
    local cf = CFrame.new(hrp.Position) * (Camera.CFrame - Camera.CFrame.Position)
    
    local corners = {
        cf * Vector3.new(-halfSize.X, halfSize.Y, halfSize.Z),
        cf * Vector3.new(halfSize.X, halfSize.Y, halfSize.Z),
        cf * Vector3.new(-halfSize.X, -halfSize.Y, halfSize.Z),
        cf * Vector3.new(halfSize.X, -halfSize.Y, halfSize.Z),
        cf * Vector3.new(-halfSize.X, halfSize.Y, -halfSize.Z),
        cf * Vector3.new(halfSize.X, halfSize.Y, -halfSize.Z),
        cf * Vector3.new(-halfSize.X, -halfSize.Y, -halfSize.Z),
        cf * Vector3.new(halfSize.X, -halfSize.Y, -halfSize.Z)
    }
    
    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge
    
    for _, corner in ipairs(corners) do
        local screenPos = Camera:WorldToViewportPoint(corner)
        if screenPos.X < minX then minX = screenPos.X end
        if screenPos.Y < minY then minY = screenPos.Y end
        if screenPos.X > maxX then maxX = screenPos.X end
        if screenPos.Y > maxY then maxY = screenPos.Y end
    end
    
    return minX, minY, maxX - minX, maxY - minY
end

