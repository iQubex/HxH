GeneralSection:Button({
    text = "Destroy & Unload",
    callback = function()
        -- 1. Disconnect all connections
        for _, conn in ipairs(State.Connections) do
            if conn.Connected then
                conn:Disconnect()
            end
        end
        table.clear(State.Connections)
        
        -- Disconnect player-specific connections
        for p, conns in pairs(State.PlayerConnections) do
            for _, conn in ipairs(conns) do
                if conn.Connected then
                    conn:Disconnect()
                end
            end
        end
        table.clear(State.PlayerConnections)
        
        -- Remove active bullet tracers
        for _, tracer in ipairs(activeBulletTracers) do
            if tracer.Line then
                tracer.Line:Remove()
            end
            if tracer.Connection then
                tracer.Connection:Disconnect()
            end
        end
        table.clear(activeBulletTracers)
        
        -- 2. Remove FOV circle drawing
        if fovCircle then
            fovCircle:Remove()
        end

        -- Remove Crosshair lines
        for _, line in ipairs(crosshairLines) do
            line:Remove()
        end
        table.clear(crosshairLines)

        -- Remove Hitmarker lines
        for _, line in ipairs(hitmarkerLines) do
            line:Remove()
        end
        table.clear(hitmarkerLines)
        
        -- 3. Remove all ESP drawing components using the robust removeEspBox routine
        for player, _ in pairs(State.EspBoxes) do
            removeEspBox(player)
        end
        table.clear(State.EspBoxes)
        
        -- 4. Reset character joints if alive
        if LocalPlayer.Character then
            local joint = getWaistJoint(LocalPlayer.Character)
            if joint and joint:IsA("Motor6D") and originalC0 then
                joint.C0 = originalC0
            end
        end
        
        -- 5. Restore camera zoom limits and offsets
        if originalCameraZoomLimits then
            LocalPlayer.CameraMinZoomDistance = originalCameraZoomLimits.Min
            LocalPlayer.CameraMaxZoomDistance = originalCameraZoomLimits.Max
        end
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid").CameraOffset = Vector3.new(0, 0, 0)
        end

        -- 6. Cleanup World Lighting settings
        cleanupLighting()
        
        -- 7. Destroy Chams Folder and player clone models
        if chamsFolder then
            chamsFolder:Destroy()
        end
        for _, cloneModel in pairs(playerClones) do
            if cloneModel then
                cloneModel:Destroy()
            end
        end
        table.clear(playerClones)

        -- 8. Destroy the ScreenGui interface
        local gui = game:GetService("CoreGui"):FindFirstChild("Neverlose")
        if gui then
            gui:Destroy()
        end
        
        -- Notification of successful unload
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Unloaded",
            Text = "HxH Hub has been fully unloaded.",
            Duration = 5
        })
    end
})

